.nav { position: fixed; left: 0; right: 0; bottom: 0; height: 142rpx; background: rgba(8,8,9,.92); backdrop-filter: blur(32rpx) saturate(1.4); border-top: 1rpx solid rgba(255,255,255,.06); display: flex; align-items: flex-start; padding: 14rpx 0 0; z-index: 50; }
.nav-compact { align-items: stretch; padding-top: 10rpx; }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding-top: 8rpx; color: #3f3f48; }
.nav-item-compact { justify-content: center; padding-top: 0; gap: 10rpx; }
.nav-ico { width: 56rpx; height: 56rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; transition: all .2s; }
.nav-lbl { font-size: 20rpx; font-weight: 700; letter-spacing: 1rpx; color: #3f3f48; }
.nav-item.on .nav-ico { background: rgba(212,245,78,.12); color: #d4f54e; transform: translateY(-6rpx) scale(1.08); }
.nav-item.on .nav-lbl { color: #d4f54e; }
.nav-fab { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; top: -28rpx; }
.fab { width: 96rpx; height: 96rpx; border-radius: 30rpx; background: #d4f54e; color: #080809; display: flex; align-items: center; justify-content: center; font-size: 46rpx; font-weight: 800; box-shadow: 0 12rpx 42rpx rgba(212,245,78,.36), 0 4rpx 14rpx rgba(212,245,78,.18); }
.fab:active { transform: scale(1.06); }
