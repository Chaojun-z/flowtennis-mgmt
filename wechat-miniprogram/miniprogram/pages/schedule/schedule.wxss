  font-size: 12px;
  font-weight: 400;
  line-height: 1.45;
}

.feedback-course-separator {
  margin: 0 10rpx;
  color: #cbd5e1;
  font-size: 12px;
  font-weight: 400;
}

.feedback-divider {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.feedback-divider text {
  color: #94a3b8;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.4;
  flex-shrink: 0;
}

.feedback-divider view {
  flex: 1;
  height: 1px;
  background: #f1f5f9;
}

.feedback-field {
  margin-bottom: 48rpx;
}

.feedback-field:last-child {
  margin-bottom: 64rpx;
}

.feedback-field-label {
  display: flex;
  align-items: baseline;
  margin-bottom: 18rpx;
  color: #0f172a;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
}

.feedback-field-label text {
  color: #ef4444;
  margin-left: 10rpx;
}

.feedback-field-label .feedback-optional {
  color: #94a3b8;
  font-size: 13px;
  font-weight: 400;
  margin-left: 18rpx;
}

.feedback-input-wrap {
  position: relative;
  min-height: 192rpx;
  padding: 26rpx 24rpx 44rpx;
  border-radius: 20rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  box-sizing: border-box;
}

.feedback-input-wrap.is-readonly {
  background: #f8fafc;
}

.feedback-input-wrap.is-active {
  border: 2rpx solid #3b5bff;
}

.feedback-input {
  width: 100%;
  height: 118rpx;
  padding: 0;
  color: #334155;
  font-size: 14px;
  font-weight: 400;
  line-height: 1.55;
  background: transparent;
  box-sizing: border-box;
}

.feedback-input[disabled] {
  color: #334155;
}

.feedback-input-placeholder {
  color: #94a3b8;
  font-size: 14px;
  font-weight: 400;
}

.feedback-count {
  position: absolute;
  right: 24rpx;
  bottom: 18rpx;
