page {
  height: 100%;
  background: #f4f6f9;
}

.app-shell {
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #f4f6f9;
  color: #18233d;
  font-family: "Inter", sans-serif;
  padding-bottom: 166rpx;
  box-sizing: border-box;
}

.custom-nav-title {
  position: absolute;
  top: 74px;
  left: 16px;
  z-index: 20;
  color: #ffffff;
  font-size: 20px;
  font-weight: 600;
  line-height: 26px;
  pointer-events: none;
}

.page-scroll {
  height: calc(100vh - 166rpx);
}

.page-bg {
  background: #f4f6f9;
}

.dashboard-top,
.timetable-top,
.students-top,
.shifts-top {
  background: linear-gradient(135deg, #2b3a55 0%, #1e2a38 100%);
  border-bottom-left-radius: 32px;
  border-bottom-right-radius: 32px;
}

.dashboard-top {
  background: linear-gradient(135deg, #2b3a55 0%, #1e2a38 100%);
  height: 230px;
  padding: 0;
  box-sizing: border-box;
}

.dashboard-hero {
  padding: 122px 32rpx 0;
}

.dashboard-coach-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.coach-banner {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.coach-avatar {
  width: 48px;
  height: 48px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}

.coach-copy {
  margin-left: 18rpx;
  min-width: 0;
}

.coach-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.coach-title {
  color: #ffffff;
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
}

.coach-arrow {
  width: 8px;
  height: 4px;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.75 0.75L4.75 4.75L8.75 0.75' stroke='white' stroke-opacity='0.8' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 8px 4px;
  flex-shrink: 0;
  transform: translateY(1px);
}

.coach-arrow::before {
  display: none;
}

.coach-subtitle {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.35;
}

.page-body {
  padding: 0 32rpx 42rpx;
}

.dashboard-shell {
  margin-top: -40px;
}

.dashboard-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.summary-card {
  padding: 28rpx 30rpx;
  border: 1px solid #eef1f6;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.03);
  color: #62728d;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.summary-left {
  text-align: left;
}

.summary-icon {
  margin-right: 12rpx;
  color: #aaa099;
}

.overview-card {
  margin-top: 0;
}

.mini-metrics {
  width: 361px;
  height: 170px;
  max-width: 100%;
  margin: 0 auto;
  padding: 16px;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(43, 58, 85, 0.04);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6px;
  box-sizing: border-box;
}

.mini-metric {
  width: 104px;
  height: 66px;
  min-height: 0;
  padding: 16px;
  text-align: left;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f8fafc;
}

.metric-primary {
  background: #f8fafc;
  box-shadow: none;
}

.metric-primary text:first-child,
.metric-primary text:last-child {
  color: inherit;
}

.mini-metric text {
  display: block;
  transform: translateY(-6px);
}

.mini-metric text:first-child {
  color: #64748b;
  font-size: 12px;
  font-weight: 400;
  line-height: 1.25;
}

.mini-metric text:last-child {
  margin-top: 8px;
  color: #0f172a;
  font-size: 24px;
  font-weight: 700;
  line-height: 1;
}

.mini-metric text.danger {
  color: #D97706;
}

.mini-metric text.conversion-value {
  color: #64748B;
  font-size: 12px;
  font-weight: 400;
}

.mini-metric text.conversion-value.has-data {
  color: #0f172a;
  font-size: 24px;
  font-weight: 700;
}

.reminder-bar {
  width: 361px;
  height: 38px;
  max-width: 100%;
  margin: 0 auto;
  margin-top: 12px;
  padding: 0 26rpx;
  border: 0.8px solid #e2e8f0;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: none;
  color: #64748b;
  display: flex;
  align-items: center;
  line-height: 1;
  box-sizing: border-box;
}

.reminder-bar .summary-icon {
  width: 16px;
  height: 16px;
  margin-right: 12px;
  background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='6.5' stroke='%2364748B' stroke-width='1.5'/%3E%3Cpath d='M8 7.25V11' stroke='%2364748B' stroke-width='1.5' stroke-linecap='round'/%3E%3Cpath d='M8 5.2V5.25' stroke='%2364748B' stroke-width='1.8' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 16px 16px;
  flex-shrink: 0;
}

.summary-icon-dot,
.summary-icon text {
  display: none;
}

.reminder-list {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 42rpx;
}

.reminder-chip {
  color: #475569;
  font-size: 12px;
  font-weight: 400;
  background: transparent;
  padding: 0;
}

.reminder-value {
  color: #0f172a;
  font-weight: 700;
}

.conversion-unit {
  font-size: 13px;
  font-weight: 400;
  color: #64748B;
}

.reminder-chip.is-danger .reminder-value {
  color: #d97706;
}

.travel-reminder {
  font-size: 12px;
}

.section-heading {
  display: flex;
  align-items: baseline;
  margin: 42rpx 0 22rpx;
}

.section-title {
  font-size: 17px;
  font-weight: 700;
  color: #0f172a;
}

.section-date {
  margin-left: 14rpx;
  color: #94a3b8;
  font-size: 13px;
  font-weight: 400;
}

.week-heading {
  margin-top: 48rpx;
}

.schedule-card,
.student-card,
.shift-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1px solid #e8eef6;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
}

.today-lesson-card {
  margin-top: 18rpx;
  padding: 0;
  width: 361px;
  height: 84px;
  max-width: 100%;
  margin-left: auto;
  margin-right: auto;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
  overflow: hidden;
  box-sizing: border-box;
}

.today-lesson-main {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 34rpx 0 24rpx;
  box-sizing: border-box;
}

.today-lesson-clock {
  width: 40px;
  height: 40px;
  margin-right: 24rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-clock {
  width: 16px;
  height: 16px;
  background-image: url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 18 18' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.75 16.75C13.1683 16.75 16.75 13.1683 16.75 8.75C16.75 4.33172 13.1683 0.75 8.75 0.75C4.33172 0.75 0.75 4.33172 0.75 8.75C0.75 13.1683 4.33172 16.75 8.75 16.75Z' stroke='%2364748B' stroke-width='1.5'/%3E%3Cpath d='M8.75 4.75V8.75L11.75 11.75' stroke='%2364748B' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 16px 16px;
}

.icon-clock-hand {
  display: none;
}

.icon-clock-hand.is-hour {
  height: 12rpx;
  margin-left: -2rpx;
  margin-top: -12rpx;
}

.icon-clock-hand.is-minute {
  height: 16rpx;
  margin-left: -2rpx;
  margin-top: -16rpx;
  transform: rotate(140deg);
}

.today-lesson-content {
  flex: 1;
  min-width: 0;
}

.today-lesson-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.today-lesson-time {
  color: #0f172a;
  font-size: 16px;
  font-weight: 700;
}

.today-course-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 18px;
  padding: 0;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 400;
  box-sizing: border-box;
}

.today-course-pill.is-private {
  border: 0.5px solid #adc6ff;
  background: #f0f5ff;
  color: #2f54eb;
}

.today-course-pill.is-trial {
  border: 0.5px solid #ffd591;
  background: #fff7e6;
  color: #fa8c16;
}

.today-course-pill.is-group {
  border: 0.5px solid #87e8de;
  background: #e6fffb;
  color: #13c2c2;
}

.today-lesson-meta {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 13px;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.today-lesson-meta.schedule-location {
  padding: 0;
  border-radius: 0;
  background: transparent;
  font-weight: 400;
}

.today-lesson-separator {
  margin: 0 12rpx;
  color: #cbd5e1;
  font-size: 13px;
}

.today-detail-btn {
  width: 70px;
  height: 28px;
  margin-left: 18rpx;
  border-radius: 999rpx;
  background: #2b3a55;
  color: #fff;
  font-size: 12px;
  font-weight: 400;
  line-height: 28px;
  flex-shrink: 0;
}

.today-empty-card {
  margin-top: 18rpx;
  height: 124rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.035);
  color: #94a3b8;
  font-size: 23rpx;
  line-height: 124rpx;
  text-align: center;
}

.week-task-card {
  width: 361px;
  height: 130px;
  max-width: 100%;
  margin: 18rpx auto 0;
  display: flex;
  align-items: center;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
  overflow: hidden;
  box-sizing: border-box;
}

.week-task-accent {
  width: 4px;
  height: 38px;
  margin-right: 16px;
  border-radius: 999rpx;
  background: #94a3b8;
  flex-shrink: 0;
  transform: translateY(-20px);
}

.week-task-main {
  flex: 1;
  min-width: 0;
  padding: 16px 16px 14px 0;
  box-sizing: border-box;
}

.week-task-topline,
.week-task-time-row,
.week-task-actions {
  display: flex;
  align-items: center;
}

.week-task-topline {
  justify-content: space-between;
}

.week-task-date {
  color: #94a3b8;
  font-size: 12px;
  font-weight: 400;
  transform: translateY(6px);
}

.week-task-status {
  width: 48px;
  height: 24px;
  padding: 0;
  border-radius: 5px;
  background: #fef3c7;
  color: #d97706;
  font-size: 11px;
  font-weight: 400;
  line-height: 24px;
  text-align: center;
  transform: translateY(10px);
}

.week-task-time-row {
  gap: 8px;
  margin-top: 8px;
  flex-wrap: wrap;
  transform: translateY(-2px);
}

.week-task-time {
  color: #0f172a;
  font-size: 15px;
  font-weight: 700;
}

.week-task-location {
  margin-top: 8px;
  color: #64748b;
  font-size: 13px;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transform: translateY(-7px);
}

.week-task-separator {
  margin: 0 12rpx;
  color: #cbd5e1;
  font-size: 13px;
}

.week-task-divider {
  width: 325px;
  max-width: 100%;
  height: 1px;
  margin-top: 8px;
  background: #f1f5f9;
  transform: translateY(-6px);
}

.week-task-actions {
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 8px;
  transform: translateY(-8px);
}

.week-task-outline,
.week-task-solid {
  width: 70px;
  min-width: 70px;
  height: 28px;
  padding: 0;
  border-radius: 999rpx;
  font-size: 12px;
  font-weight: 400;
  line-height: 28px;
}

.week-task-outline {
  width: 70px;
  height: 28px;
  border: 1px solid #e2e8f0;
  background: #fff;
  color: #475569;
}

.week-task-solid {
  width: 70px;
  height: 28px;
  background: #2b3a55;
  color: #fff;
}

.schedule-card-head,
.shift-head,
.shift-meta-row,
.student-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.schedule-time {
  color: #2d2621;
  font-size: 30rpx;
  font-weight: 800;
}

.muted-icon {
  margin-right: 10rpx;
  color: #a8a099;
  font-size: 26rpx;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  font-size: 19rpx;
  font-weight: 500;
}

.tag-danger {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-green {
  background: #e6fffb;
  color: #13c2c2;
}

.tag-gray {
  background: #f1f5f9;
  color: #64748b;
}

.schedule-card-main {
  margin-top: 22rpx;
  padding: 26rpx 22rpx;
  border-radius: 18rpx;
  border: 1px solid #f0ece6;
  background: #fcfbf9;
}

.schedule-student {
  color: #2d2621;
  font-size: 32rpx;
  font-weight: 800;
}

.schedule-meta {
  margin-top: 14rpx;
  color: #7f7770;
  font-size: 25rpx;
}

.schedule-location {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f1eb;
  color: #5f5751;
  font-size: 24rpx;
  font-weight: 600;
}

.location-icon {
  margin-right: 10rpx;
  color: #b3733f;
}

.course-pill {
  display: inline-block;
  margin-right: 14rpx;
  padding: 6rpx 12rpx;
  border: 1px solid #e8e2da;
  border-radius: 6rpx;
  color: #b3733f;
  background: #fff;
  font-size: 21rpx;
  font-weight: 700;
}

.schedule-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.week-todo-card {
  border: 1px solid #eee8e1;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(45, 38, 33, 0.04);
  overflow: hidden;
}

.week-todo-group {
  padding: 24rpx 26rpx;
  border-bottom: 1px solid #f0ece6;
}

.week-todo-group:last-child {
  border-bottom: 0;
}

.week-todo-day {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.week-todo-marker {
  width: 8rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: #d19a74;
}

.week-todo-label {
  margin-left: 14rpx;
  color: #6a625b;
  font-size: 27rpx;
  font-weight: 800;
}

.week-todo-count {
  margin-left: auto;
  color: #a69c94;
  font-size: 23rpx;
  font-weight: 700;
}

.week-todo-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.week-todo-row + .week-todo-row {
  border-top: 1px solid #f3eee8;
}

.week-todo-main {
  min-width: 0;
  flex: 1;
}

.week-todo-title,
.week-todo-location {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.week-todo-title {
  color: #2d2621;
  font-size: 28rpx;
  font-weight: 800;
}

.week-todo-location {
  margin-top: 8rpx;
  color: #80776f;
  font-size: 24rpx;
}

.week-status {
  margin-left: 18rpx;
  flex-shrink: 0;
}

button {
  margin: 0;
  border-radius: 12rpx;
}

button::after {
  border: 0;
}

.primary-btn,
.outline-btn,
.ghost-btn,
.solid-btn,
.back-week-btn {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn,
.solid-btn {
  background: #b3733f;
  color: #fff;
}

.outline-btn {
  background: #fff;
  color: #574f49;
  border: 1px solid #e4ddd5;
}

.ghost-btn {
  background: #fff;
  color: #b3733f;
  border: 1px solid #b3733f;
}

.timetable-page {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #f4f6f9;
}

.timetable-top {
  height: 210px;
  padding: 115px 16px 0;
  background: linear-gradient(135deg, #2b3a55 0%, #1e2a38 100%);
  border-bottom-left-radius: 32px;
  border-bottom-right-radius: 32px;
  box-sizing: border-box;
  position: relative;
}

.students-top {
  height: 210px;
  position: relative;
}

.shifts-top {
  height: 210px;
  padding: 0 40rpx;
  box-sizing: border-box;
  position: relative;
}

.week-toolbar {
  margin-top: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.week-switch {
  width: 160px;
  min-width: 0;
  height: 36px;
  padding: 0;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  box-sizing: border-box;
}

.switch-btn {
  position: relative;
  width: 8px;
  height: 10px;
  line-height: 10px;
  padding: 0;
  background: transparent;
  color: transparent;
  font-size: 0;
  font-weight: 500;
}

.switch-btn::after {
  border: 0;
}

.switch-btn::before {
  content: "";
  position: absolute;
  top: 0;
  width: 8px;
  height: 10px;
  box-sizing: border-box;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 8px 10px;
}

.switch-prev::before {
  left: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='8' height='10' viewBox='0 0 8 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M6.75 0.75L0.75 4.75L6.75 8.75' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
}

.switch-next::before {
  right: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='8' height='10' viewBox='0 0 8 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.75 0.75L6.75 4.75L0.75 8.75' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
}

.week-range {
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}

.back-week-btn {
  width: 80px;
  min-width: 80px;
  height: 36px;
  padding: 0;
  border-radius: 999rpx;
  background: #fff;
  color: #2b3a55;
  font-size: 13px;
  font-weight: 500;
  line-height: 36px;
}

.timetable-scroll {
  flex: 1;
  height: 0;
  margin-top: -45px;
  white-space: nowrap;
  background: #fff;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  overflow: hidden;
}

.timetable-panel {
