  align-items: center;
  justify-content: center;
  padding: 0;
}

.feedback-action-btn.is-ghost {
  color: #475569;
  background: #fff;
  border: 1px solid #e2e8f0;
}

.feedback-action-btn.is-primary {
  color: #fff;
  background: #2b3a55;
  border: 0;
}

.feedback-action-btn.is-poster text {
  margin-right: 16rpx;
  color: #fde047;
  font-size: 18px;
  line-height: 1;
}

.poster-sheet {
