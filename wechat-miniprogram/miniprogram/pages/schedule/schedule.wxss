  align-items: center;
  min-width: 0;
}

.coach-menu-icon {
  width: 20px;
  height: 20px;
  margin-right: 12px;
  position: relative;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 20px 20px;
}

