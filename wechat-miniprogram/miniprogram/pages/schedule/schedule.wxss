.coach-menu-item-text {
  flex: 1;
  min-width: 0;
  text-align: left;
  font-size: 15px;
  font-weight: 500;
  color: #0f172a;
}

.coach-menu-divider {
  height: 1px;
  margin: 0 16px;
  background: #f1f5f9;
}

.coach-menu-chevron {
  width: 11px;
  height: 11px;
  background-image: url("data:image/svg+xml,%3Csvg width='8' height='14' viewBox='0 0 8 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L7 7L1 13' stroke='%23CBD5E1' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 6px 12px;
  flex-shrink: 0;
}

.coach-menu-danger-card,
.coach-menu-cancel-card {
  width: 100%;
  height: 56px;
  border-radius: 16px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 16px rgba(15, 23, 42, 0.04);
}

.coach-menu-danger-card {
  margin-bottom: 16px;
  color: #ef4444;
  font-size: 16px;
  font-weight: 600;
}

.coach-menu-cancel-card {
  color: #475569;
  font-size: 16px;
  font-weight: 600;
}

.sheet-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 38rpx;
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 700;
}

.sheet-title button {
  width: 56rpx;
  height: 56rpx;
  line-height: 50rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 30rpx;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  padding: 12rpx 32rpx 28rpx;
  box-sizing: border-box;
}

.feedback-sheet {
  height: calc(100vh - 352rpx);
  background: #fff;
}

.feedback-sheet-handle {
  margin-top: 24rpx;
  margin-bottom: 28rpx;
}

.feedback-sheet-head {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx 34rpx;
}

.feedback-sheet-title {
  color: #0f172a;
  font-size: 17px;
  font-weight: 700;
  line-height: 48rpx;
}

.feedback-sheet-close {
  position: absolute;
  right: 32rpx;
  top: -6rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 50rpx;
  border-radius: 50%;
  background: #f1f5f9;
  color: #64748b;
  font-size: 30rpx;
  font-weight: 400;
  padding: 0;
}

.feedback-sheet-body {
  flex: 1;
  min-height: 0;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

.feedback-course-card {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 136rpx;
  margin-bottom: 36rpx;
  padding: 26rpx 20rpx 26rpx 40rpx;
  border-radius: 24rpx;
  border: 1px solid #f1f5f9;
  background: #f8fafc;
  box-sizing: border-box;
  overflow: hidden;
}

.feedback-course-bar {
  position: absolute;
  left: 0;
  top: 50%;
  width: 8rpx;
  height: 72rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: #2b3a55;
  transform: translateY(-50%);
}

.feedback-course-content {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.feedback-course-time {
  color: #0f172a;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.45;
}

.feedback-course-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 12rpx;
