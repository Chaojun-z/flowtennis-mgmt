  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 6a2 2 0 0 1 2-2h4l1.5 2H18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6z' fill='%232B3A55'/%3E%3Crect x='8' y='12' width='8' height='2' rx='1' fill='%23FFFFFF'/%3E%3C/svg%3E");
}

.tab-classes-icon:not(.active) {
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 6a2 2 0 0 1 2-2h4l1.5 2H18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6z' stroke='%2394A3B8' stroke-width='2' fill='none' stroke-linejoin='round'/%3E%3Cpath d='M8 13h8' stroke='%2394A3B8' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E");
}

.tab-grid-icon {
  width: 36rpx;
  height: 36rpx;
  margin-top: 6rpx;
  margin-bottom: 10rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 7rpx;
}

.tab-grid-icon view {
  border-radius: 2rpx;
  box-sizing: border-box;
}

.tab-item.active .tab-grid-icon view {
  background: #2b3a55;
}

.tab-item:not(.active) .tab-grid-icon view {
  border: 3rpx solid #94a3b8;
  background: transparent;
}

.tab-calendar-icon {
  width: 38rpx;
  height: 38rpx;
  margin-top: 5rpx;
  margin-bottom: 7rpx;
}

.tab-calendar-head,
.tab-calendar-body {
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  border: 3rpx solid currentColor;
  box-sizing: border-box;
}

.tab-calendar-head {
  top: 7rpx;
  height: 10rpx;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
}

.tab-calendar-body {
  top: 16rpx;
  bottom: 4rpx;
  border-radius: 0 0 6rpx 6rpx;
}

.tab-calendar-bind {
  position: absolute;
  top: 3rpx;
  width: 3rpx;
  height: 9rpx;
  border-radius: 999rpx;
  background: currentColor;
  z-index: 1;
}

.tab-calendar-bind.is-left {
  left: 13rpx;
}

.tab-calendar-bind.is-right {
  right: 13rpx;
}

.tab-user-icon {
  width: 38rpx;
  height: 38rpx;
  margin-top: 5rpx;
  margin-bottom: 7rpx;
}

.tab-user-head,
.tab-user-body {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  box-sizing: border-box;
}

.tab-user-head {
  top: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
}

.tab-user-body {
  bottom: 4rpx;
  width: 30rpx;
  height: 18rpx;
  border-radius: 16rpx 16rpx 0 0;
}

.tab-item.active .tab-user-head,
.tab-item.active .tab-user-body {
  background: #2b3a55;
}

.tab-item:not(.active) .tab-user-head {
  border: 3rpx solid #94a3b8;
}

.tab-item:not(.active) .tab-user-body {
  border: 3rpx solid #94a3b8;
  border-bottom: 0;
}

.tab-list-icon {
  width: 42rpx;
  height: 34rpx;
  margin-top: 7rpx;
  margin-bottom: 9rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.tab-list-icon view {
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-home-indicator {
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  width: 262rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.8);
  transform: translateX(-50%);
}

.mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 110;
  height: 85vh;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  background: #fff;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
  transition: transform .28s ease;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 80rpx;
  height: 10rpx;
  margin: 24rpx auto 10rpx;
  border-radius: 999rpx;
  background: #cbd5e1;
}

.coach-menu-sheet {
  height: auto;
  background: #f4f6f9;
  padding: 0 16px calc(36px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  box-shadow: 0 -12px 32px rgba(15, 23, 42, 0.16);
}

.coach-menu-handle {
  width: 40px;
  height: 6px;
  margin-top: 12px;
  margin-bottom: 24px;
  background: #cbd5e1;
}

.coach-menu-profile {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 2px;
  margin-bottom: 28px;
}

.coach-menu-avatar {
  width: 52px;
  height: 52px;
  border-radius: 999px;
  background: #e2e8f0;
  color: #475569;
  font-size: 22px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.coach-menu-profile-copy {
