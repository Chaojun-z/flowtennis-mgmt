page {
  height: 100%;
  background: #f4f6f9;
}

.app-shell {
  height: 100vh;
  overflow: hidden;
  background: #f4f6f9;
  color: #18233d;
  font-family: "Inter", sans-serif;
  padding-bottom: 166rpx;
  box-sizing: border-box;
}

.page-scroll {
  height: calc(100vh - 166rpx);
}

.page-bg {
  background: #f4f6f9;
}

.dashboard-top,
.timetable-top,
.students-top,
.shifts-top {
  background: linear-gradient(135deg, #2b3a55 0%, #1e2a38 100%);
  border-bottom-left-radius: 32px;
  border-bottom-right-radius: 32px;
}

.dashboard-top {
  background: linear-gradient(135deg, #2b3a55 0%, #1e2a38 100%);
  padding: 0 0 98rpx;
}

.dashboard-hero {
  padding: 132rpx 32rpx 0;
}

.dashboard-coach-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.coach-banner {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.coach-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999px;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.coach-copy {
  margin-left: 18rpx;
  min-width: 0;
}

.coach-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.coach-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.2;
}

.coach-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  height: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 16rpx;
  line-height: 1;
  transform: translateY(2rpx);
}

.coach-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 25rpx;
  font-weight: 400;
  line-height: 1.35;
}

.danger {
  color: #d45b41;
}

.page-body {
  padding: 0 32rpx 42rpx;
}

.dashboard-shell {
  margin-top: -24rpx;
}

.dashboard-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.summary-card {
  padding: 28rpx 30rpx;
  border: 1px solid #eef1f6;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.03);
  color: #62728d;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.summary-left {
  text-align: left;
}

.summary-icon {
  margin-right: 12rpx;
  color: #aaa099;
}

.overview-card {
  margin-top: 0;
}

.mini-metrics {
  padding: 32rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(43, 58, 85, 0.04);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.mini-metric {
  min-height: 132rpx;
  padding: 22rpx 20rpx 18rpx;
  text-align: left;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #f8fafc;
}

.metric-primary {
  background: #f8fafc;
  box-shadow: none;
}

.metric-primary text:first-child,
.metric-primary text:last-child {
  color: inherit;
}

.mini-metric text {
  display: block;
}

.mini-metric text:first-child {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 400;
  line-height: 1.25;
}

.mini-metric text:last-child {
  margin-top: 16rpx;
  color: #0f172a;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.mini-metric text.danger {
  color: #0f172a;
}

.reminder-bar {
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border: 1px solid #d8e2ef;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 22rpx rgba(43, 58, 85, 0.035);
  color: #64748b;
  display: flex;
  align-items: flex-start;
}

.reminder-bar .summary-icon {
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  margin-top: 4rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #edf1f7;
  color: #94a3b8;
  text-align: center;
  font-size: 22rpx;
}

.reminder-list {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 26rpx;
}

.reminder-chip {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 400;
  background: transparent;
  padding: 0;
}

.reminder-chip text + text {
  margin-left: 8rpx;
  color: #1e2a44;
  font-weight: 600;
}

.reminder-chip.is-danger text + text {
  color: #f5a623;
}

.section-heading {
  display: flex;
  align-items: baseline;
  margin: 42rpx 0 22rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e2a44;
}

.section-date {
  margin-left: 14rpx;
  color: #94a3b8;
  font-size: 25rpx;
  font-weight: 400;
}

.week-heading {
  margin-top: 48rpx;
}

.schedule-card,
.student-card,
.shift-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1px solid #e8eef6;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
}

.today-lesson-card {
  margin-top: 18rpx;
  padding: 0;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
  overflow: hidden;
}

.today-lesson-main {
  display: flex;
  align-items: center;
  padding: 42rpx 24rpx 42rpx 24rpx;
}

.today-lesson-clock {
  width: 104rpx;
  height: 104rpx;
  margin-right: 24rpx;
  border-radius: 999rpx;
  background: #eef2f8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-clock {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #6b7f9f;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.icon-clock-hand {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  border-radius: 999rpx;
  background: #6b7f9f;
  transform-origin: 50% 100%;
}

.icon-clock-hand.is-hour {
  height: 12rpx;
  margin-left: -2rpx;
  margin-top: -12rpx;
}

.icon-clock-hand.is-minute {
  height: 16rpx;
  margin-left: -2rpx;
  margin-top: -16rpx;
  transform: rotate(140deg);
}

.today-lesson-content {
  flex: 1;
  min-width: 0;
}

.today-lesson-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.today-lesson-time {
  color: #1e2a44;
  font-size: 29rpx;
  font-weight: 700;
}

.today-course-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 34rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  font-size: 19rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.today-course-pill.is-private {
  border: 2rpx solid #b7c7ff;
  background: #f2f5ff;
  color: #5474ff;
}

.today-course-pill.is-trial {
  border: 2rpx solid #ffd18d;
  background: #fff5df;
  color: #f59e0b;
}

.today-course-pill.is-group {
  border: 2rpx solid #a6edf0;
  background: #ecffff;
  color: #0fbfc7;
}

.today-lesson-location,
.today-lesson-student {
  margin-top: 14rpx;
  color: #7b8ba6;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.today-lesson-location.schedule-location {
  padding: 0;
  border-radius: 0;
  background: transparent;
  font-weight: 400;
}

.today-detail-btn {
  width: 144rpx;
  height: 76rpx;
  margin-left: 18rpx;
  border-radius: 999rpx;
  background: #2b3a55;
  color: #fff;
  font-size: 23rpx;
  font-weight: 500;
  line-height: 76rpx;
  flex-shrink: 0;
}

.today-empty-card {
  margin-top: 18rpx;
  height: 124rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.035);
  color: #94a3b8;
  font-size: 23rpx;
  line-height: 124rpx;
  text-align: center;
}

.week-task-card {
  margin-top: 18rpx;
  display: flex;
  align-items: stretch;
  border-radius: 34rpx;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
  overflow: hidden;
}

.week-task-accent {
  width: 10rpx;
  margin: 52rpx 0 52rpx 0;
  border-radius: 999rpx;
  background: #97a8c3;
  flex-shrink: 0;
}

.week-task-main {
  flex: 1;
  padding: 28rpx 32rpx 24rpx 30rpx;
}

.week-task-topline,
.week-task-time-row,
.week-task-actions {
  display: flex;
  align-items: center;
}

.week-task-topline {
  justify-content: space-between;
}

.week-task-date {
  color: #94a3b8;
  font-size: 25rpx;
}

.week-task-status {
  height: 46rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #fff5d8;
  color: #e7a93b;
  font-size: 19rpx;
  font-weight: 500;
  line-height: 46rpx;
}

.week-task-time-row {
  gap: 14rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.week-task-time {
  color: #1e2a44;
  font-size: 29rpx;
  font-weight: 700;
}

.week-task-location {
  margin-top: 18rpx;
  color: #7b8ba6;
  font-size: 23rpx;
}

.week-task-divider {
  height: 2rpx;
  margin-top: 26rpx;
  background: #edf1f7;
}

.week-task-actions {
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 22rpx;
}

.week-task-outline,
.week-task-solid {
  min-width: 146rpx;
  height: 74rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 500;
  line-height: 74rpx;
}

.week-task-outline {
  border: 2rpx solid #d9e2ee;
  background: #fff;
  color: #4f6488;
}

.week-task-solid {
  background: #2b3a55;
  color: #fff;
}

.schedule-card-head,
.shift-head,
.shift-meta-row,
.student-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.schedule-time {
  color: #2d2621;
  font-size: 30rpx;
  font-weight: 800;
}

.muted-icon {
  margin-right: 10rpx;
  color: #a8a099;
  font-size: 26rpx;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  font-size: 19rpx;
  font-weight: 500;
}

.tag-danger {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-green {
  background: #e6fffb;
  color: #13c2c2;
}

.tag-gray {
  background: #f1f5f9;
  color: #64748b;
}

.schedule-card-main {
  margin-top: 22rpx;
  padding: 26rpx 22rpx;
  border-radius: 18rpx;
  border: 1px solid #f0ece6;
  background: #fcfbf9;
}

.schedule-student {
  color: #2d2621;
  font-size: 32rpx;
  font-weight: 800;
}

.schedule-meta {
  margin-top: 14rpx;
  color: #7f7770;
  font-size: 25rpx;
}

.schedule-location {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f1eb;
  color: #5f5751;
  font-size: 24rpx;
  font-weight: 600;
}

.location-icon {
  margin-right: 10rpx;
  color: #b3733f;
}

.course-pill {
  display: inline-block;
  margin-right: 14rpx;
  padding: 6rpx 12rpx;
  border: 1px solid #e8e2da;
  border-radius: 6rpx;
  color: #b3733f;
  background: #fff;
  font-size: 21rpx;
  font-weight: 700;
}

.schedule-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.week-todo-card {
  border: 1px solid #eee8e1;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(45, 38, 33, 0.04);
  overflow: hidden;
}

.week-todo-group {
  padding: 24rpx 26rpx;
  border-bottom: 1px solid #f0ece6;
}

.week-todo-group:last-child {
  border-bottom: 0;
}

.week-todo-day {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.week-todo-marker {
  width: 8rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: #d19a74;
}

.week-todo-label {
  margin-left: 14rpx;
  color: #6a625b;
  font-size: 27rpx;
  font-weight: 800;
}

.week-todo-count {
  margin-left: auto;
  color: #a69c94;
  font-size: 23rpx;
  font-weight: 700;
}

.week-todo-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.week-todo-row + .week-todo-row {
  border-top: 1px solid #f3eee8;
}

.week-todo-main {
  min-width: 0;
  flex: 1;
}

.week-todo-title,
.week-todo-location {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.week-todo-title {
  color: #2d2621;
  font-size: 28rpx;
  font-weight: 800;
}

.week-todo-location {
  margin-top: 8rpx;
  color: #80776f;
  font-size: 24rpx;
}

.week-status {
  margin-left: 18rpx;
  flex-shrink: 0;
}

button {
  margin: 0;
  border-radius: 12rpx;
}

button::after {
  border: 0;
}

.primary-btn,
.outline-btn,
.ghost-btn,
.solid-btn,
.back-week-btn {
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn,
.solid-btn {
  background: #b3733f;
  color: #fff;
}

.outline-btn {
  background: #fff;
  color: #574f49;
  border: 1px solid #e4ddd5;
}

.ghost-btn {
  background: #fff;
  color: #b3733f;
  border: 1px solid #b3733f;
}

.timetable-page {
  height: calc(100vh - 112rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #f4f6f9;
}

.timetable-top {
  padding: 92rpx 24rpx 48rpx;
  border-bottom-left-radius: 32px;
  border-bottom-right-radius: 32px;
}

.timetable-top .top-title {
  text-align: center;
  font-size: 32rpx;
}

.students-top .top-title,
.shifts-top .top-title {
  font-size: 42rpx;
}

.students-top {
  min-height: 360rpx;
}

.shifts-top {
  padding: 92rpx 28rpx 56rpx;
}

.top-title {
  color: #fff;
  text-align: left;
  font-size: 32rpx;
  font-weight: 600;
}

.week-toolbar {
  margin-top: 28rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.week-switch {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-btn {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  background: transparent;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}

.week-range {
  color: #fff;
  font-size: 25rpx;
  font-weight: 400;
}

.back-week-btn {
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #2b3a55;
  font-size: 23rpx;
  font-weight: 500;
}

.timetable-scroll-y {
  flex: 1;
  height: 0;
  margin-top: -18rpx;
  background: #f4f6f9;
}

.timetable-scroll {
  flex: 1;
  white-space: nowrap;
  background: #fff;
  min-height: 100%;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
}

.tt-header,
.tt-body,
.tt-day-columns {
  display: flex;
}

.tt-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #fff;
  border-bottom: 1px solid #eef2f7;
}

.tt-time-corner,
.tt-time-axis {
  width: 86rpx;
  flex-shrink: 0;
  border-right: 1px solid #eef2f7;
  background: #fff;
}

.tt-day-head,
.tt-day-column {
  width: 240rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  border-right: 1px solid #eef2f7;
}

.tt-day-head {
  padding: 18rpx 0 14rpx;
  text-align: center;
}

.tt-day-head-active,
.tt-day-column-active {
  background: #f8fafc;
}

.tt-day-name {
  display: block;
  color: #64748b;
  font-size: 23rpx;
  font-weight: 400;
}

.tt-day-date {
  display: block;
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 19rpx;
}

.tt-day-head-active .tt-day-name,
.tt-day-head-active .tt-day-date {
  color: #2b3a55;
}

.tt-hour-cell,
.tt-grid-hour {
  height: 150rpx;
  border-bottom: 1px solid #f1f5f9;
  box-sizing: border-box;
}

.tt-hour-cell {
  display: flex;
  justify-content: center;
}

.tt-hour-cell text {
  margin-top: -14rpx;
  padding: 0 4rpx;
  background: #fff;
  color: #94a3b8;
  font-size: 19rpx;
}

.tt-day-columns,
.tt-day-column {
  position: relative;
}

.tt-empty {
  position: absolute;
  top: 52rpx;
  left: 24rpx;
  right: 24rpx;
  height: 86rpx;
  line-height: 86rpx;
  border: 1px dashed #dbe4ef;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #94a3b8;
  text-align: center;
  font-size: 23rpx;
  font-weight: 400;
}

.tt-course {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  padding: 18rpx;
  border: 1px solid #d9e3f2;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(43, 58, 85, 0.04);
  box-sizing: border-box;
  overflow: hidden;
}

.tt-course-top {
  display: flex;
  justify-content: space-between;
  color: #1e2a44;
  font-size: 19rpx;
  font-weight: 500;
}

.tt-course-name {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 27rpx;
  font-weight: 600;
}

.tt-course-meta,
.tt-course-foot {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
}

.tt-course-foot {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
}

.tt-now-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 975rpx;
  z-index: 25;
  height: 1px;
  background: #5474ff;
}

.tt-now-line text {
  position: absolute;
  left: -76rpx;
  top: -18rpx;
  width: 70rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 999rpx;
  background: #5474ff;
  color: #fff;
  text-align: center;
  font-size: 19rpx;
  font-weight: 500;
}

.students-body {
  margin-top: -80rpx;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.students-summary {
  margin-top: 0;
  min-height: 188rpx;
  padding: 0;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(43, 58, 85, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.student-list {
  margin-top: 36rpx;
}

.students-top + .page-body,
.shifts-top + .page-body {
  margin-top: -18rpx;
}

.students-top + .students-body {
  margin-top: -80rpx;
}

