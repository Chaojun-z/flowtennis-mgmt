  color: #64748b;
  font-size: 13px;
  font-weight: 400;
  line-height: 18px;
}

.coach-menu-group {
  margin-bottom: 16px;
  border-radius: 16px;
  background: #fff;
  overflow: hidden;
  box-shadow: 0 6px 16px rgba(15, 23, 42, 0.04);
}

.coach-menu-item {
  height: 56px;
  padding: 0 16px;
  border-radius: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coach-menu-item-top {
  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}

.coach-menu-item-bottom {
  border-bottom-left-radius: 16px;
  border-bottom-right-radius: 16px;
}

.coach-menu-item-left {
