  left: 13rpx;
}

.tab-calendar-bind.is-right {
  right: 13rpx;
}

.tab-user-icon {
  width: 38rpx;
  height: 38rpx;
  margin-top: 5rpx;
  margin-bottom: 7rpx;
}

.tab-user-head,
.tab-user-body {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  box-sizing: border-box;
}

.tab-user-head {
  top: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
}

.tab-user-body {
  bottom: 4rpx;
  width: 30rpx;
  height: 18rpx;
