  padding: 0 16px;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  background: #ffffff;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.loading-shell-tip-line {
  width: 72%;
  height: 10px;
  border-radius: 999px;
  background: #e2e8f0;
}

.loading-shell-list {
  margin-top: 16px;
}

.loading-shell-item {
  padding: 16px;
  border-radius: 16px;
  background: #ffffff;
  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.03);
}

.loading-shell-item + .loading-shell-item {
  margin-top: 16px;
}

.loading-shell-item-head,
.loading-shell-item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.loading-shell-item-title {
  width: 168px;
  height: 16px;
  border-radius: 8px;
  background: #cbd5e1;
}

.loading-shell-item-title.is-second {
  width: 152px;
}

.loading-shell-item-tag {
  width: 44px;
  height: 18px;
  border-radius: 4px;
  background: #e2e8f0;
}

.loading-shell-item-lines {
  margin-top: 18px;
}

.loading-shell-item-line {
  width: 78%;
  height: 11px;
  border-radius: 999px;
  background: #e2e8f0;
}

.loading-shell-item-line + .loading-shell-item-line {
  margin-top: 12px;
}

.loading-shell-item-line.is-short {
  width: 58%;
}

.loading-shell-item-line.is-mid {
  width: 66%;
}

.loading-shell-item-footer {
  margin-top: 20px;
  padding-top: 12px;
  border-top: 1px solid #f1f5f9;
}

.loading-shell-item-progress {
  width: 112px;
  height: 11px;
  border-radius: 999px;
  background: #cbd5e1;
}

.loading-shell-item-button {
  width: 80px;
  height: 28px;
  border-radius: 999px;
  background: #e2e8f0;
}

.loading-shell-pulse {
  animation: loadingPulse 1.4s ease-in-out infinite;
}

.tab-loading {
  min-height: 100vh;
  padding-top: 220rpx;
  color: #94a3b8;
  font-size: 28rpx;
  text-align: center;
  background: #f4f6f9;
  box-sizing: border-box;
}

@keyframes loadingPulse {
  0% {
    opacity: 0.45;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.45;
  }
}

.empty-box {
  margin: 160rpx 40rpx;
  padding: 48rpx 40rpx;
  border-radius: 18rpx;
  background: #fff;
}

.empty-title {
  display: block;
  color: #6f655e;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}
