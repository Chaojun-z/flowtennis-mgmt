.detail-note-col {
  flex: 1;
  min-width: 0;
}

.detail-note-label {
  display: block;
  margin-bottom: 16rpx;
  color: #64748b;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.5;
}

.detail-note-text,
.detail-note-box {
  color: #475569;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.6;
}

.detail-note-text.is-empty,
.detail-note-box.is-empty {
  color: #94a3b8;
}

.detail-note-box {
  margin-top: 8rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1px solid #f1f5f9;
  box-sizing: border-box;
}

.detail-feedback-top {
  display: flex;
  gap: 32rpx;
  margin-bottom: 26rpx;
}

.detail-feedback-card.is-empty-state .detail-note-block {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.detail-feedback-card.is-empty-state .detail-note-block .detail-note-label {
  flex: 0 0 auto;
  min-width: 0;
  margin-right: 28rpx;
  margin-bottom: 0;
}

.detail-feedback-card.is-filled .detail-note-block {
  display: block;
}

.detail-feedback-cell {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.detail-feedback-cell .detail-note-label {
  flex: 0 0 144rpx;
  min-width: 144rpx;
  margin-bottom: 0;
}

.detail-feedback-value {
  display: block;
  color: #0f172a;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.5;
}

.detail-feedback-pending {
  color: #f59e0b;
}

.detail-sheet-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 64rpx;
  background: #fff;
  border-top: 1px solid #f1f5f9;
  box-shadow: 0 -2rpx 6rpx rgba(15, 23, 42, 0.03);
  flex-shrink: 0;
}

.detail-sheet-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 15px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.detail-sheet-btn.is-ghost {
  color: #475569;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
}

.detail-sheet-btn.is-primary {
  color: #fff;
  background: #2b3a55;
  border: 0;
}

.state-text {
  padding: 120rpx 0;
  color: #b3733f;
  text-align: center;
  font-size: 30rpx;
}

.empty-box {
  margin: 160rpx 40rpx;
  padding: 48rpx 40rpx;
  border-radius: 18rpx;
  background: #fff;
}

.empty-title {
  display: block;
  color: #6f655e;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}
