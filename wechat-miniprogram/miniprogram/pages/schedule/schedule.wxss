  font-family: Courier, monospace;
  font-weight: 400;
  line-height: 1;
}

.feedback-sheet-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 64rpx;
  background: #fff;
  border-top: 1px solid #f1f5f9;
  box-shadow: 0 -2rpx 6rpx rgba(15, 23, 42, 0.03);
  flex-shrink: 0;
}

.feedback-action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 15px;
