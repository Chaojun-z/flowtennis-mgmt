.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  height: 166rpx;
  padding: 16rpx 16rpx 68rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  box-sizing: border-box;
}

.tab-item {
  width: 120rpx;
  height: 82rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.tab-item.active {
  color: #2b3a55;
  font-weight: 600;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin: 2rpx auto 6rpx;
  position: relative;
  color: inherit;
  box-sizing: border-box;
}

.tab-grid-icon {
  width: 36rpx;
  height: 36rpx;
  margin-top: 6rpx;
  margin-bottom: 10rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 7rpx;
}

.tab-grid-icon view {
  border-radius: 2rpx;
  box-sizing: border-box;
}

.tab-item.active .tab-grid-icon view {
  background: #2b3a55;
}

.tab-item:not(.active) .tab-grid-icon view {
  border: 3rpx solid #94a3b8;
  background: transparent;
}

.tab-calendar-icon {
  width: 38rpx;
  height: 38rpx;
  margin-top: 5rpx;
  margin-bottom: 7rpx;
}

.tab-calendar-head,
.tab-calendar-body {
  position: absolute;
  left: 5rpx;
  right: 5rpx;
  border: 3rpx solid currentColor;
  box-sizing: border-box;
}

.tab-calendar-head {
  top: 7rpx;
  height: 10rpx;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
}

.tab-calendar-body {
  top: 16rpx;
  bottom: 4rpx;
  border-radius: 0 0 6rpx 6rpx;
}

.tab-calendar-bind {
  position: absolute;
  top: 3rpx;
  width: 3rpx;
  height: 9rpx;
  border-radius: 999rpx;
  background: currentColor;
  z-index: 1;
}

