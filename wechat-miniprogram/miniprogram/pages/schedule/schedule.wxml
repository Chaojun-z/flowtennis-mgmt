<view class="app-shell">
  <view wx:if="{{loading}}" class="state-text">课表加载中...</view>

  <view wx:elif="{{error}}" class="empty-box">
    <text class="empty-title">{{error}}</text>
    <button class="primary-btn" bindtap="openWebview">进入完整教练端</button>
  </view>

  <block wx:else>
    <scroll-view wx:if="{{isDashboard}}" scroll-y class="page-scroll page-bg">
      <view class="dashboard-top">
        <view class="coach-banner">
          <view class="coach-avatar">教练</view>
          <view class="coach-copy">
            <view class="coach-title">早安，王教练 <text class="coach-arrow">⌄</text></view>
            <view class="coach-subtitle">准备好今天的教学了吗？</view>
          </view>
        </view>
      </view>

      <view class="page-body">
        <view class="mini-metrics overview-card">
          <view class="mini-metric metric-primary"><text>今日课程</text><text>{{stats.today}}</text></view>
          <view class="mini-metric"><text>本周课时</text><text>{{stats.week}}</text></view>
          <view class="mini-metric"><text>本月课时</text><text>{{stats.month}}</text></view>
          <view class="mini-metric"><text>本月反馈</text><text>{{stats.feedback}}</text></view>
          <view class="mini-metric"><text>未反馈</text><text class="danger">{{stats.pending}}</text></view>
          <view class="mini-metric"><text>体验转化</text><text>{{stats.conversion}}</text></view>
        </view>

        <view wx:if="{{reminderItems.length}}" class="reminder-bar">
          <text class="summary-icon">ⓘ</text>
          <view class="reminder-list">
            <view wx:for="{{reminderItems}}" wx:key="label" class="reminder-chip {{item.itemClass}}">
              <text>{{item.label}}</text>
              <text>{{item.value}}</text>
            </view>
          </view>
        </view>

        <view class="section-heading">
          <text class="section-title">今日排课</text>
          <text class="section-date">{{todayLabel}}</text>
        </view>

        <view wx:for="{{dashboardClasses}}" wx:key="id" class="schedule-card">
          <view class="schedule-card-head">
            <text class="schedule-time"><text class="muted-icon">◷</text>{{item.timeText}}</text>
            <text class="status-tag {{item.statusClass}}">{{item.status}}</text>
          </view>
          <view class="schedule-card-main">
            <view class="schedule-student">{{item.student}}</view>
            <view class="schedule-meta"><text class="course-pill">{{item.type}}</text></view>
            <view class="schedule-location"><text class="location-icon">⌖</text>{{item.loc}}</view>
          </view>
          <view class="schedule-actions">
            <button class="outline-btn" data-id="{{item.id}}" bindtap="openDetail">查看详情</button>
            <button class="solid-btn" data-id="{{item.id}}" bindtap="openFeedbackById">填写反馈</button>
          </view>
        </view>

        <view wx:if="{{!dashboardClasses.length}}" class="summary-card">今天暂无课程</view>

        <view class="section-heading week-heading">
          <text class="section-title">本周待办</text>
          <text class="section-date">{{weekRange}}</text>
        </view>

        <view wx:if="{{weekTodoGroups.length}}" class="week-todo-card">
          <view wx:for="{{weekTodoGroups}}" wx:key="key" class="week-todo-group">
            <view class="week-todo-day">
              <text class="week-todo-marker"></text>
              <text class="week-todo-label">{{item.label}}</text>
              <text class="week-todo-count">{{item.countText}}</text>
            </view>
            <view wx:for="{{item.items}}" wx:for-item="todo" wx:key="id" class="week-todo-row" data-id="{{todo.id}}" bindtap="openDetail">
              <view class="week-todo-main">
                <text class="week-todo-title">{{todo.shortMeta}}</text>
                <text class="week-todo-location">{{todo.shortLocation}}</text>
              </view>
              <text class="status-tag week-status {{todo.todoClass}}">{{todo.todoLabel}}</text>
            </view>
          </view>
        </view>

        <view wx:else class="summary-card">本周暂无待办课程</view>
      </view>
    </scroll-view>

    <view wx:if="{{isTimetable}}" class="timetable-page">
      <view class="timetable-top">
        <view class="top-title">我的课表</view>
        <view class="week-toolbar">
          <view class="week-switch">
            <button class="switch-btn" bindtap="prevWeek">‹</button>
            <text class="week-range">{{weekRange}}</text>
            <button class="switch-btn" bindtap="nextWeek">›</button>
          </view>
          <button class="back-week-btn" bindtap="goCurrentWeek">回到本周</button>
        </view>
      </view>

      <scroll-view scroll-x scroll-y class="timetable-scroll">
        <view class="tt-header">
          <view class="tt-time-corner"></view>
          <view wx:for="{{timetableDays}}" wx:key="key" class="tt-day-head {{item.headClass}}">
            <text class="tt-day-name">{{item.name}}</text>
            <text class="tt-day-date">{{item.date}}</text>
          </view>
        </view>

        <view class="tt-body">
          <view class="tt-time-axis">
            <view wx:for="{{timetableHours}}" wx:key="*this" class="tt-hour-cell"><text>{{item}}</text></view>
          </view>

          <view class="tt-day-columns">
            <view wx:if="{{isCurrentWeek}}" class="tt-now-line"><text>13:30</text></view>
            <view wx:for="{{timetableDays}}" wx:key="key" class="tt-day-column {{item.columnClass}}">
              <view wx:for="{{timetableHours}}" wx:key="*this" class="tt-grid-hour"></view>
              <view wx:if="{{!item.items.length}}" class="tt-empty">暂无课程</view>
              <view wx:for="{{item.items}}" wx:for-item="course" wx:key="id" class="tt-course" style="{{course.blockStyle}}" data-id="{{course.id}}" bindtap="openDetail">
                <view class="tt-course-top"><text>{{course.timeText}}</text><text>{{course.type}}</text></view>
                <view class="tt-course-name">{{course.student}}</view>
                <view class="tt-course-meta">{{course.loc}}</view>
                <view class="tt-course-foot">反馈: {{course.status}}</view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <scroll-view wx:if="{{isStudents}}" scroll-y class="page-scroll page-bg">
      <view class="students-top">
        <view class="top-title">我的学员</view>
        <view class="students-summary">
          <view class="students-summary-block"><text class="students-number">{{studentStats.visibleCount}}</text><text class="students-caption">可见学员</text></view>
          <view class="students-divider"></view>
          <view class="students-summary-block"><text class="students-number">{{studentStats.ownerCount}}</text><text class="students-caption">负责学员</text></view>
        </view>
      </view>

      <view class="page-body">
        <view wx:for="{{studentsList}}" wx:key="id" class="student-card">
          <view class="student-avatar {{item.avatarClass}}">{{item.avatarText}}</view>
          <view class="student-main">
            <view class="student-row"><text class="student-name">{{item.name}}</text><text class="student-tag">{{item.type}}</text></view>
            <view class="student-meta">累计上课：<text class="student-strong">{{item.cumulative}}</text> 节</view>
            <view wx:if="{{item.showProgress}}" class="student-meta">课包进度：<text class="student-strong">{{item.progress}}</text></view>
          </view>
          <text class="student-chevron">›</text>
        </view>
      </view>
    </scroll-view>

    <scroll-view wx:if="{{isShifts}}" scroll-y class="page-scroll page-bg">
      <view class="shifts-top">
        <view class="top-title">我的班次</view>
        <view class="shift-summary-row">
          <view class="shift-summary-card">
            <text class="shift-summary-label">我的班次</text>
            <text class="shift-summary-value">{{shiftStats.totalCount}} <text>个</text></text>
            <text class="shift-summary-foot">进行中 {{shiftStats.activeCount}}</text>
          </view>
          <view class="shift-summary-card">
            <text class="shift-summary-label">总课时 / 已上</text>
            <text class="shift-summary-value">{{shiftStats.totalLessons}} / {{shiftStats.usedLessons}}</text>
            <text class="shift-summary-foot">剩余 {{shiftStats.remainingLessons}} 节</text>
          </view>
        </view>
      </view>

      <view class="page-body">
        <view class="summary-card summary-left">这里查看你当前负责的班次，可快速了解学员名单、课时进度和班次时间。</view>
        <view wx:for="{{shiftsList}}" wx:key="id" class="shift-card">
          <view class="shift-head">
            <view class="shift-head-left">
              <text class="shift-name">{{item.name}}</text>
              <text class="status-tag {{item.statusClass}}">{{item.status}}</text>
            </view>
            <text class="shift-link">详情</text>
          </view>
          <view class="shift-meta-row"><text>学员：{{item.student}}</text><text>课时进度：<text class="shift-strong">{{item.progress}}</text></text></view>
        </view>
        <view class="bottom-end">已经到底啦</view>
      </view>
    </scroll-view>

    <view class="tabbar">
      <view class="tab-item {{dashboardTabClass}}" data-tab="dashboard" bindtap="switchTab"><text class="tab-icon">▦</text><text>工作台</text></view>
      <view class="tab-item {{timetableTabClass}}" data-tab="timetable" bindtap="switchTab"><text class="tab-icon">□</text><text>我的课表</text></view>
      <view class="tab-item {{studentsTabClass}}" data-tab="students" bindtap="switchTab"><text class="tab-icon">♙</text><text>我的学员</text></view>
      <view class="tab-item {{shiftsTabClass}}" data-tab="shifts" bindtap="switchTab"><text class="tab-icon">☷</text><text>我的班次</text></view>
    </view>

    <view wx:if="{{showDetail || showFeedback}}" class="mask" catchtouchmove="stopMove" bindtap="closeSheets"></view>

    <view class="sheet {{detailSheetClass}}" catchtouchmove="stopMove">
      <view class="sheet-handle"></view>
      <view class="sheet-title"><text>排课详情</text><button bindtap="closeSheets">×</button></view>
      <scroll-view scroll-y class="sheet-body">
        <view class="block-title">课程基础信息</view>
        <view class="info-card">
          <view class="info-row"><text>时间</text><text>{{selectedClass.timeText}}</text></view>
          <view class="info-row"><text>学员</text><text>{{selectedClass.student}}</text></view>
          <view class="info-row"><text>课程</text><text>{{selectedClass.type}}</text></view>
          <view class="info-row"><text>地点</text><text>{{selectedClass.loc}}</text></view>
          <view class="info-row"><text>状态</text><text>{{selectedClass.status}}</text></view>
        </view>
      </scroll-view>
      <view class="sheet-actions">
        <button class="outline-btn" bindtap="closeSheets">关闭</button>
        <button class="solid-btn" bindtap="openFeedback">填写反馈</button>
      </view>
    </view>

    <view class="sheet {{feedbackSheetClass}}" catchtouchmove="stopMove">
      <view class="sheet-handle"></view>
      <view class="sheet-title"><text>课后反馈</text><button bindtap="closeSheets">×</button></view>
      <scroll-view scroll-y class="sheet-body">
        <view class="feedback-context">{{selectedClass.timeText}} · {{selectedClass.student}}</view>
        <view class="field-label">今天练习了 <text>*</text></view>
        <textarea class="feedback-input" placeholder="请输入内容..." value="{{feedbackForm.practicedToday}}" bindinput="onFeedbackInput" />
      </scroll-view>
      <view class="sheet-actions three">
        <button class="outline-btn" bindtap="closeSheets">取消</button>
        <button class="ghost-btn" bindtap="openPoster">生成海报</button>
        <button class="solid-btn" bindtap="saveFeedback" loading="{{savingFeedback}}">保存反馈</button>
      </view>
    </view>
  </block>
</view>
