page {
  height: 100%;
  background: #f4f6f9;
}

.entry-page {
  min-height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24px;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #2b3a55 0%, #1e2a38 35%, #f4f6f9 60%, #f4f6f9 100%);
}

.entry-card {
  width: 345px;
  min-height: 420px;
  padding: 32px;
  border-radius: 24px;
  background: #ffffff;
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.entry-title {
  display: block;
  color: #0f172a;
  font-size: 24px;
  font-weight: 800;
  letter-spacing: 1px;
  text-align: center;
  line-height: 1.25;
}

.entry-subtitle {
  display: block;
  margin-top: 8px;
  margin-bottom: 56px;
  color: #64748b;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-align: center;
  line-height: 1.4;
}

.entry-field {
  margin-bottom: 20px;
}

.entry-field-password {
  margin-bottom: 0;
}

.entry-label {
  display: block;
  margin-bottom: 8px;
  color: #475569;
  font-size: 13px;
  font-weight: 600;
  line-height: 1.3;
}

.entry-input {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  background: #f8fafc;
  color: #0f172a;
  font-size: 14px;
  font-weight: 400;
  box-sizing: border-box;
}

.entry-placeholder {
  color: #94a3b8;
  font-size: 14px;
}

.login-btn {
  width: 100%;
  height: 48px;
  margin-top: 32px;
  border-radius: 999px;
  background: #2b3a55;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 4px;
  line-height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: 0;
}

.login-spinner {
  width: 16px;
  height: 16px;
  margin-right: 8px;
  border: 2px solid rgba(255, 255, 255, 0.35);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: loginSpin 0.8s linear infinite;
}

@keyframes loginSpin {
  to {
    transform: rotate(360deg);
  }
}

.agreement-group {
  margin-top: 20px;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
}

.agreement-row checkbox {
  transform: scale(0.85);
  transform-origin: left top;
}

.agreement-copy {
  flex: 1;
  margin-left: 8px;
  color: #64748b;
  font-size: 12px;
  line-height: 1.6;
}

.agreement-link {
  color: #2b3a55;
  font-weight: 600;
}

.agreement-gap {
  display: inline-block;
  width: 4px;
}

.entry-orb {
  position: absolute;
  border-radius: 999px;
  background: #ffffff;
  pointer-events: none;
}

.entry-orb-right {
  width: 240px;
  height: 240px;
  top: -70px;
  right: -77px;
  opacity: 0.03;
}

.entry-orb-left {
  width: 160px;
  height: 160px;
  top: 70px;
  left: -40px;
  opacity: 0.02;
}
