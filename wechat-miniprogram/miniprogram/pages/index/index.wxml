<view class="entry-page">
  <view class="entry-orb entry-orb-right"></view>
  <view class="entry-orb entry-orb-left"></view>
  <view class="entry-card">
    <text class="entry-title">网球兄弟</text>
    <text class="entry-subtitle">FLOWTENNIS · 管理系统</text>

    <view class="entry-field">
      <text class="entry-label">账号</text>
      <input class="entry-input" placeholder="请输入账号或手机号" placeholder-class="entry-placeholder" value="{{account}}" bindinput="onAccountInput" />
    </view>

    <view class="entry-field entry-field-password">
      <text class="entry-label">密码</text>
      <input class="entry-input" password="{{true}}" placeholder="请输入密码" placeholder-class="entry-placeholder" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <checkbox-group class="agreement-group" bindchange="onAgreementChange">
      <label class="agreement-row">
        <checkbox value="agree" checked="{{agreed}}" color="#2B3A55" />
        <view class="agreement-copy">
          <text>我已阅读并同意</text>
          <text class="agreement-link" bindtap="openAgreement">《用户协议》</text>
          <text class="agreement-gap"></text>
          <text class="agreement-link" bindtap="openPrivacy">《隐私政策》</text>
        </view>
      </label>
    </checkbox-group>

    <button class="login-btn" loading="{{loggingIn}}" bindtap="submitLogin">登录</button>
  </view>
</view>
