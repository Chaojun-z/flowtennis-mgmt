<view class="create-page">
  <view class="create-card">
    <text class="create-title">发布约球</text>
    <text class="create-subtitle">最小发布表单，权限已通过手机号和后台运营账号联动。</text>

    <input class="create-input" placeholder="标题" data-field="title" bindinput="onInput" />
    <input class="create-input" placeholder="类型：single 或 double" data-field="matchType" bindinput="onInput" />
    <input class="create-input" placeholder="目标人数，例如 4" data-field="targetHeadcount" bindinput="onInput" />
    <input class="create-input" placeholder="最低水平，可留空" data-field="ntrpMin" bindinput="onInput" />
    <input class="create-input" placeholder="最高水平，可留空" data-field="ntrpMax" bindinput="onInput" />
    <input class="create-input" placeholder="性别偏好：不限/男生/女生" data-field="genderPreference" bindinput="onInput" />
    <input class="create-input" placeholder="预估场地费" data-field="estimatedCourtFee" bindinput="onInput" />
    <input class="create-input" placeholder="场地名称" data-field="venueName" bindinput="onInput" />
    <input class="create-input" placeholder="开始时间，例如 2026-05-12T19:00:00" data-field="startTime" bindinput="onInput" />
    <input class="create-input" placeholder="结束时间，例如 2026-05-12T21:00:00" data-field="endTime" bindinput="onInput" />

    <button class="submit-btn" bindtap="submitMatch">
      <text>{{submitting ? '提交中...' : '提交发布'}}</text>
    </button>
  </view>
</view>
