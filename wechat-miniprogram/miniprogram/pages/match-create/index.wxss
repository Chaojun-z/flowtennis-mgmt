.create-page {
  min-height: 100%;
  padding: 20px;
  box-sizing: border-box;
  background: #f8fafc;
}

.create-card {
  background: #ffffff;
  border-radius: 18px;
  padding: 20px;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
}

.create-title {
  display: block;
  color: #0f172a;
  font-size: 22px;
  font-weight: 700;
}

.create-subtitle {
  display: block;
  margin-top: 8px;
  margin-bottom: 18px;
  color: #64748b;
  font-size: 12px;
  line-height: 1.6;
}

.create-input {
  width: 100%;
  height: 44px;
  margin-bottom: 12px;
  padding: 0 14px;
  border: 1px solid #dbe2ea;
  border-radius: 12px;
  box-sizing: border-box;
  background: #ffffff;
  font-size: 14px;
}

.submit-btn {
  margin-top: 8px;
  height: 46px;
  border-radius: 999px;
  background: #0f172a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
}

.submit-btn::after {
  border: 0;
}
