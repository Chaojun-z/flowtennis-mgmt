<view class="profile-page">
  <view class="profile-card">
    <text class="profile-title">约球个人页</text>
    <text class="profile-subtitle">先绑定手机号，再让后台手机号与运营账号对上。</text>

    <view class="profile-row">
      <text class="profile-label">当前昵称</text>
      <text class="profile-value">{{user.nickName || '微信用户'}}</text>
    </view>
    <view class="profile-row">
      <text class="profile-label">手机号</text>
      <text class="profile-value">{{user.phone || '未绑定'}}</text>
    </view>
    <view class="profile-row">
      <text class="profile-label">发布权限</text>
      <text class="profile-value {{user.canCreateMatch ? 'is-granted' : 'is-pending'}}">{{user.canCreateMatch ? 'canCreateMatch 已生效' : '待绑定或后台未勾约球运营'}}</text>
    </view>

    <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <text>{{bindingPhone ? '绑定中...' : (user.phone ? '重新授权手机号' : '授权手机号') }}</text>
    </button>

    <button class="create-btn" bindtap="goCreateMatch" disabled="{{!user.canCreateMatch}}">
      <text>发布约球</text>
    </button>

    <text wx:if="{{!user.canCreateMatch}}" class="profile-tip">后台账号需填写同一个手机号并勾选约球运营。</text>
  </view>
</view>
