.page { min-height: 100vh; background: #080809; color: #eeece4; font-family: "PingFang SC", "Avenir Next", sans-serif; padding-bottom: 150rpx; }
.prof-hero { padding: 34rpx 40rpx 38rpx; border-bottom: 1rpx solid rgba(255,255,255,.05); }
.prof-row { display: flex; align-items: flex-start; gap: 28rpx; margin-bottom: 36rpx; }
.prof-row-guest { padding: 8rpx 0 0; }
.prof-login-hit { display: flex; align-items: flex-start; gap: 28rpx; flex: 1; min-width: 0; }
.prof-ava { width: 128rpx; height: 128rpx; border-radius: 40rpx; background: linear-gradient(135deg, rgba(212,245,78,.2), rgba(92,159,255,.2)); border: 1rpx solid rgba(255,255,255,.1); display: flex; align-items: center; justify-content: center; font-family: Georgia, serif; font-style: italic; font-size: 52rpx; color: #d4f54e; flex-shrink: 0; }
.prof-ava-image { overflow: hidden; }
.prof-main { flex: 1; min-width: 0; }
.prof-name { font-size: 38rpx; font-weight: 800; color: #eeece4; letter-spacing: -1rpx; margin-bottom: 4rpx; }
.prof-login-entry { display: inline-flex; margin-top: 10rpx; padding: 10rpx 22rpx; border-radius: 999rpx; background: rgba(212,245,78,.12); border: 1rpx solid rgba(212,245,78,.18); color: #d4f54e; font-size: 22rpx; font-weight: 700; }
.prof-sub { font-size: 24rpx; color: #7c7b85; }
.prof-tags { display: flex; gap: 12rpx; margin: -8rpx 0 20rpx; flex-wrap: wrap; }
.profile-tag { padding: 8rpx 20rpx; border-radius: 12rpx; font-size: 22rpx; font-weight: 700; }
.profile-tag { background: rgba(255,255,255,.06); color: #eeece4; border: 1rpx solid rgba(255,255,255,.08); }
.pt-acid { background: rgba(212,245,78,.12); color: #d4f54e; border: 1rpx solid rgba(212,245,78,.2); }
.profile-phone-btn { margin: 0 0 20rpx; height: 80rpx; border-radius: 999rpx; background: #1e1e23; color: #eeece4; font-size: 26rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.profile-form-card { margin-top: -8rpx; background: #121216; border: 1rpx solid rgba(255,255,255,.07); border-radius: 28rpx; padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.profile-form-row { display: flex; align-items: center; gap: 20rpx; }
.profile-avatar-picker { width: 112rpx; height: 112rpx; padding: 0; margin: 0; border-radius: 32rpx; overflow: hidden; background: #1e1e23; border: 1rpx solid rgba(255,255,255,.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.profile-avatar-picker::after { border: none; }
.profile-avatar-preview { width: 100%; height: 100%; }
.profile-avatar-empty { font-size: 24rpx; color: #7c7b85; }
.profile-nickname-input { flex: 1; height: 88rpx; border-radius: 22rpx; background: #1a1a20; border: 1rpx solid rgba(255,255,255,.08); color: #eeece4; font-size: 28rpx; padding: 0 24rpx; box-sizing: border-box; }
.profile-save-btn { height: 84rpx; border-radius: 999rpx; background: #d4f54e; color: #101012; font-size: 28rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; }
.profile-save-btn[disabled] { opacity: .55; }
.ntrp-setter { display: inline-flex; margin-top: 16rpx; padding: 12rpx 22rpx; border-radius: 999rpx; background: #1e1e23; color: #eeece4; font-size: 22rpx; font-weight: 800; }
.card { background: #161619; border-radius: 28rpx; padding: 28rpx; color: #7c7b85; }
.error-panel { background: linear-gradient(180deg, rgba(26,26,31,.96), rgba(18,18,22,.96)); border: 1rpx solid rgba(255,255,255,.07); border-radius: 28rpx; padding: 28rpx; display: flex; flex-direction: column; gap: 22rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,.04); }
.error-mark { width: 56rpx; height: 56rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; background: rgba(212,245,78,.12); color: #d4f54e; font-size: 32rpx; font-weight: 800; }
.error-copy { display: flex; flex-direction: column; gap: 10rpx; }
.error-title { font-size: 30rpx; line-height: 1; color: #eeece4; font-weight: 800; }
.error-desc { color: #7c7b85; font-size: 24rpx; line-height: 1.6; }
.error-btn { height: 84rpx; border-radius: 999rpx; background: #d4f54e; color: #101012; font-size: 28rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; }
.profile-skeleton, .calendar-skeleton, .record-skeleton { position: relative; overflow: hidden; }
.profile-skeleton::after, .calendar-skeleton::after, .record-skeleton::after, .profile-skeleton-ava::after, .profile-skeleton-line::after, .profile-skeleton-pill::after, .profile-skeleton-stat::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,.05) 45%, transparent 100%); transform: translateX(-100%); animation: profileShimmer 1.5s linear infinite; }
.profile-skeleton { background: #161619; border-radius: 28rpx; padding: 28rpx; border: 1rpx solid rgba(255,255,255,.07); margin-top: 8rpx; }
.profile-skeleton-top { display: flex; gap: 28rpx; align-items: flex-start; margin-bottom: 36rpx; }
.profile-skeleton-ava { width: 128rpx; height: 128rpx; border-radius: 40rpx; background: #1e1e23; position: relative; overflow: hidden; flex-shrink: 0; }
.profile-skeleton-main { flex: 1; }
.profile-skeleton-line { height: 26rpx; border-radius: 14rpx; background: #232329; position: relative; overflow: hidden; }
.profile-skeleton-pill { width: 180rpx; height: 44rpx; margin-top: 22rpx; border-radius: 12rpx; background: #232329; position: relative; overflow: hidden; }
.profile-skeleton-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 12rpx; }
.profile-skeleton-stat { height: 108rpx; border-radius: 20rpx; background: #1e1e23; position: relative; overflow: hidden; }
.prof-stats { display: grid; grid-template-columns: repeat(4,1fr); border-radius: 32rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,.06); }
.ps-item { padding: 24rpx 0; text-align: center; border-right: 1rpx solid rgba(255,255,255,.06); }
.ps-item:last-child { border-right: none; }
.ps-n { font-family: Georgia, serif; font-style: italic; font-size: 42rpx; color: #eeece4; line-height: 1; }
.ps-n.acid { color: #d4f54e; }
.ps-l { font-size: 20rpx; color: #7c7b85; margin-top: 8rpx; letter-spacing: 1rpx; }
.calendar-section, .record-section { padding: 38rpx 40rpx 0; }
.section-title { font-size: 22rpx; font-weight: 800; letter-spacing: 4rpx; color: #7c7b85; margin-bottom: 28rpx; }
.calendar-card { background: #0f0f12; border: 1rpx solid rgba(255,255,255,.07); border-radius: 32rpx; padding: 26rpx; }
.calendar-skeleton { height: 320rpx; background: #0f0f12; border: 1rpx solid rgba(255,255,255,.07); border-radius: 32rpx; }
.cal-grid { display: grid; grid-template-rows: repeat(7, 1fr); grid-template-columns: repeat(13, minmax(0, 1fr)); grid-auto-flow: column; gap: 12rpx; }
.cal-dot { width: 100%; padding-top: 100%; border-radius: 9rpx; background: #1e1e23; }
.cal-dot.lv1 { background: rgba(212,245,78,.22); }
.cal-dot.lv2 { background: rgba(212,245,78,.48); }
.cal-dot.lv3 { background: #d4f54e; }
.cal-meta { display: flex; justify-content: space-between; color: #7c7b85; font-size: 22rpx; margin-top: 20rpx; }
.ab-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.ab-name { font-size: 24rpx; font-weight: 700; color: #eeece4; width: 80rpx; flex-shrink: 0; }
.ab-track { flex: 1; height: 8rpx; background: #1e1e23; border-radius: 999rpx; overflow: hidden; }
.ab-fill { height: 100%; border-radius: 999rpx; background: #d4f54e; }
.ab-val { font-family: Menlo, monospace; font-size: 20rpx; color: #7c7b85; width: 56rpx; text-align: right; }
.empty-profile-card { background: #161619; border: 1rpx solid rgba(255,255,255,.07); border-radius: 28rpx; padding: 26rpx; color: #7c7b85; font-size: 24rpx; line-height: 1.55; }
.record-card { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.06); }
.record-skeleton-wrap { display: flex; flex-direction: column; gap: 20rpx; }
.record-skeleton { height: 112rpx; border-radius: 28rpx; background: #161619; border: 1rpx solid rgba(255,255,255,.07); }
.my-matches-entry { margin-bottom: 24rpx; height: 84rpx; border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,.08); background: #161619; color: #eeece4; font-size: 26rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.record-date { width: 72rpx; flex-shrink: 0; font-family: Georgia, serif; font-style: italic; font-size: 36rpx; color: #d4f54e; }
.record-main { flex: 1; min-width: 0; }
.record-title { font-size: 28rpx; font-weight: 800; color: #eeece4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.record-sub { color: #7c7b85; font-size: 22rpx; margin-top: 6rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.record-status { flex-shrink: 0; color: #7c7b85; font-size: 22rpx; }
.w180 { width: 180rpx; }
@keyframes profileShimmer { from { transform: translateX(-100%); } to { transform: translateX(100%); } }
