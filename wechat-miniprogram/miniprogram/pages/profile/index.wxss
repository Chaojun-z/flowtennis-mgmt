.profile-page {
  min-height: 100%;
  padding: 24px;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef4ff 0%, #f8fafc 100%);
}

.profile-card {
  background: #ffffff;
  border-radius: 20px;
  padding: 24px 20px;
  box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
}

.profile-title {
  display: block;
  color: #0f172a;
  font-size: 22px;
  font-weight: 700;
}

.profile-subtitle {
  display: block;
  margin-top: 8px;
  margin-bottom: 20px;
  color: #64748b;
  font-size: 13px;
  line-height: 1.6;
}

.profile-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #e2e8f0;
}

.profile-label {
  color: #475569;
  font-size: 14px;
}

.profile-value {
  max-width: 58%;
  color: #0f172a;
  font-size: 14px;
  font-weight: 600;
  text-align: right;
}

.is-granted {
  color: #15803d;
}

.is-pending {
  color: #b45309;
}

.phone-btn,
.create-btn {
  margin-top: 18px;
  border-radius: 999px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
}

.phone-btn {
  background: #1d4ed8;
  color: #ffffff;
}

.phone-btn::after,
.create-btn::after {
  border: 0;
}

.create-btn {
  background: #0f172a;
  color: #ffffff;
}

.create-btn[disabled] {
  background: #cbd5e1;
  color: #ffffff;
}

.profile-tip {
  display: block;
  margin-top: 12px;
  color: #94a3b8;
  font-size: 12px;
  line-height: 1.6;
}
