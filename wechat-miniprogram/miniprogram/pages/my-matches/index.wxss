.page { min-height: 100vh; background: #080809; color: #eeece4; font-family: "PingFang SC", "Avenir Next", sans-serif; }
.hist-section { padding: 34rpx 40rpx 160rpx; }
.page-eyebrow { font-size: 21rpx; font-weight: 800; letter-spacing: 5rpx; color: #d4f54e; margin-bottom: 12rpx; }
.title { font-family: Georgia, serif; font-style: italic; font-size: 68rpx; line-height: 1.06; margin-bottom: 34rpx; }
.hist-item { display: flex; align-items: center; gap: 24rpx; padding: 26rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.05); }
.hist-date { width: 64rpx; text-align: center; flex-shrink: 0; }
.hd-d { font-family: Georgia, serif; font-style: italic; font-size: 40rpx; color: #eeece4; line-height: 1; }
.hd-m { font-size: 18rpx; color: #7c7b85; font-weight: 900; letter-spacing: 1rpx; margin-top: 4rpx; }
.hist-info { flex: 1; min-width: 0; }
.hi-t { font-size: 28rpx; font-weight: 800; color: #eeece4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hi-s { font-size: 22rpx; color: #7c7b85; margin-top: 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hist-res { text-align: right; flex-shrink: 0; }
.hr-score { font-family: Menlo, monospace; font-size: 22rpx; color: #d4f54e; }
.hr-cost { font-size: 20rpx; color: #3f3f48; margin-top: 4rpx; }
.empty { color: #7c7b85; font-size: 26rpx; padding-top: 30rpx; }
.retry { margin-top: 24rpx; background: #1e1e23; color: #eeece4; border-radius: 24rpx; }
