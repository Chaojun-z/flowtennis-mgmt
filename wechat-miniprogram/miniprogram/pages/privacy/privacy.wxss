.doc-page {
  height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
}

.doc-card {
  min-height: 80vh;
  margin: 16px 16px 24px;
  padding: 24px 24px 36px;
  border-radius: 24px;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
}

.doc-head {
  margin-bottom: 32px;
}

.doc-title {
  display: block;
  color: #0f172a;
  font-size: 22px;
  font-weight: 800;
  line-height: 31px;
}

.doc-meta {
  display: block;
  margin-top: 8px;
  color: #94a3b8;
  font-size: 12px;
  font-weight: 400;
  line-height: 17px;
}

.doc-section + .doc-section {
  margin-top: 32px;
}

.doc-section-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.doc-section-marker {
  width: 4px;
  height: 14px;
  border-radius: 999px;
  background: #2b3a55;
  flex-shrink: 0;
}

.doc-section-title {
  color: #0f172a;
  font-size: 15px;
  font-weight: 700;
  line-height: 21px;
}

.doc-paragraph {
  display: block;
  color: #475569;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.85;
  text-align: justify;
}

.doc-link-card {
  width: 313px;
  max-width: 100%;
  height: 56px;
  margin-top: 20px;
  padding: 0 16px;
  border-radius: 16px;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.doc-link-card::after {
  border: 0;
}

