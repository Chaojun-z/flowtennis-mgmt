# staging 应连接独立 staging 数据源，不得复用 production
APP_ENV=staging
DATA_ENV=staging

TS_ENDPOINT=https://staging-tablestore.example.com
TS_INSTANCE=flow-staging
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-me
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-me

JWT_SECRET=replace-me-staging

MATCH_DATABASE_URL=postgres://user:pass@staging-db.example.com:5432/flowtennis_staging
MATCH_DATABASE_SSL=true

ENABLE_DEFAULT_USER_BOOTSTRAP=false
ENABLE_TABLE_BOOTSTRAP=false
ENABLE_RUNTIME_TABLE_ENSURE=false
ENABLE_DEFAULT_PRICE_PLAN_BOOTSTRAP=false
ENABLE_MABAO_FINANCE_SEED_BOOTSTRAP=false
ENABLE_IMPORTED_LEDGER_AUTO_REPAIR=false

ALLOW_PRODUCTION_BOOTSTRAP_WRITES=false
ALLOW_PRODUCTION_DATA_FOR_NON_PROD=false
